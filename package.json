{
  "name": "video-meeting-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "powershell -NoProfile -Command \"if (Test-Path '.next/dev/lock') { Remove-Item '.next/dev/lock' -Force }\"",
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "dev:webpack": "next dev --webpack",
    "dev:reset": "powershell -NoProfile -Command \"$ports = 3000,3001; foreach ($p in $ports) { Get-NetTCPConnection -State Listen -LocalPort $p -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess -Unique | ForEach-Object { Stop-Process -Id $_ -Force -ErrorAction SilentlyContinue } }; if (Test-Path '.next/dev/lock') { Remove-Item '.next/dev/lock' -Force }; Write-Output 'DEV_RESET_DONE'\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:schema:apply": "tsx scripts/apply-db-schema.ts",
    "secure-files:rotate-keys": "tsx scripts/rotate-direct-message-file-keys.ts",
    "jobs:worker": "tsx scripts/background-job-worker.ts",
    "cleanup:secure-files": "tsx scripts/cleanup-secure-files.ts",
    "cleanup:recordings": "tsx scripts/cleanup-recordings.ts",
    "smoke:meeting-intel": "tsx scripts/smoke-meeting-intelligence.ts",
    "backfill:meeting-intel": "tsx scripts/backfill-meeting-intelligence.ts",
    "token:service": "tsx scripts/generate-service-token.ts",
    "signaling:dev": "tsx server/signaling-server.ts",
    "signaling:start": "node server/dist/signaling-server.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1013.0",
    "@aws-sdk/s3-request-presigner": "^3.1013.0",
    "@tensorflow-models/body-pix": "^2.2.1",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "clsx": "^2.1.1",
    "cookie": "^1.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "mediasoup": "^3.15.9",
    "mediasoup-client": "^3.9.7",
    "next": "16.1.6",
    "pg": "^8.16.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "ws": "^8.18.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/pg": "^8.15.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
